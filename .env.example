# Binance
BINANCE_API_KEY=
BINANCE_SECRET=
USE_TESTNET=true
LIVE_TRADING_REVIEWED=false
TESTNET_TRADE_COUNT=0

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://botuser:strongpassword@localhost:5432/crypto_bot
POSTGRES_DB=crypto_bot
POSTGRES_USER=botuser
POSTGRES_PASSWORD=strongpassword

# Trading universe
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,ADAUSDT
TIMEFRAMES=1m,5m,15m,1h,4h,1d

# Risk controls
MAX_RISK_PER_TRADE_PCT=1
MAX_DAILY_LOSS_PCT=4
MAX_WEEKLY_LOSS_PCT=8
MAX_CONCURRENT_TRADES=3
CONFIDENCE_THRESHOLD=0.70
MAX_PORTFOLIO_RISK_PCT=3
DRAWDOWN_CIRCUIT_BREAKER_PCT=10

# Optional public data APIs
CRYPTOCOMPARE_API_KEY=
ECONOMIC_CALENDAR_API_URL=
REQUIRE_ECONOMIC_CALENDAR=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
